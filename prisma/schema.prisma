generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  ANALYST
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum StudyStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum FinancialType {
  BUDGET
  REVENUE
  EXPENSE
  INVESTMENT
}

enum ClientStage {
  LEAD
  QUALIFIED
  PROPOSAL
  ACTIVE
  INACTIVE
}

enum SupplierStatus {
  PROSPECT
  APPROVED
  ACTIVE
  SUSPENDED
}

enum InvestorStatus {
  PROSPECT
  ENGAGED
  DUE_DILIGENCE
  COMMITTED
  INACTIVE
}

enum InquiryType {
  QUOTE
  CONSULTATION
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
  SPAM
}

model Organization {
  id               String             @id @default(uuid()) @db.Uuid
  name             String
  slug             String             @unique
  country          String             @default("Kenya")
  currency         String             @default("USD") @db.VarChar(3)
  fiscalYearStart  Int                @default(1)
  createdAt        DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(6)
  profiles         Profile[]
  projects         Project[]
  feasibility      FeasibilityStudy[]
  financialRecords FinancialRecord[]
  clients          Client[]
  suppliers        Supplier[]
  investors        Investor[]
  documents        Document[]
  auditLogs        AuditLog[]
}

model Profile {
  id             String        @id @db.Uuid
  email          String        @unique
  fullName       String?
  role           UserRole      @default(MEMBER)
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)

  @@index([organizationId])
}

model Project {
  id                 String             @id @default(uuid()) @db.Uuid
  code               String
  name               String
  description        String?
  sector             String
  location           String
  status             ProjectStatus      @default(PLANNING)
  budget             Decimal            @default(0) @db.Decimal(18, 2)
  startDate          DateTime?           @db.Date
  endDate            DateTime?           @db.Date
  clientId           String?             @db.Uuid
  client             Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organizationId     String              @db.Uuid
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          String              @db.Uuid
  feasibilityStudies FeasibilityStudy[]
  financialRecords   FinancialRecord[]
  documents          Document[]
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(6)

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([clientId])
}

model FeasibilityStudy {
  id               String       @id @default(uuid()) @db.Uuid
  title            String
  projectId        String       @db.Uuid
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status           StudyStatus  @default(DRAFT)
  executiveSummary String
  marketScore      Int?
  technicalScore   Int?
  financialScore   Int?
  riskScore        Int?
  overallScore     Int?
  recommendation   String?
  organizationId   String       @db.Uuid
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        String       @db.Uuid
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)

  @@index([organizationId, status])
  @@index([projectId])
}

model FinancialRecord {
  id              String        @id @default(uuid()) @db.Uuid
  type            FinancialType
  category        String
  description     String
  amount          Decimal       @db.Decimal(18, 2)
  currency        String        @db.VarChar(3)
  transactionDate DateTime      @db.Date
  projectId       String?       @db.Uuid
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  organizationId  String        @db.Uuid
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       String        @db.Uuid
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)

  @@index([organizationId, type])
  @@index([projectId])
  @@index([transactionDate])
}

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  contactName    String
  email          String
  phone          String?
  country        String
  stage          ClientStage  @default(LEAD)
  estimatedValue Decimal      @default(0) @db.Decimal(18, 2)
  notes          String?
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]
  createdBy      String       @db.Uuid
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)

  @@index([organizationId, stage])
  @@index([email])
}

model Supplier {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  category       String
  contactName    String
  email          String
  phone          String?
  country        String
  status         SupplierStatus @default(PROSPECT)
  rating         Int            @default(0)
  notes          String?
  organizationId String         @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String         @db.Uuid
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(6)

  @@index([organizationId, status])
}

model Investor {
  id                String         @id @default(uuid()) @db.Uuid
  name              String
  organizationName  String?
  email             String
  phone             String?
  country           String
  status            InvestorStatus @default(PROSPECT)
  investmentRange   String
  focusAreas        String
  lastContactedAt   DateTime?       @db.Date
  notes             String?
  organizationId    String         @db.Uuid
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         String         @db.Uuid
  createdAt         DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(6)

  @@index([organizationId, status])
}

model Document {
  id             String       @id @default(uuid()) @db.Uuid
  title          String
  category       String
  storageBucket  String
  storagePath    String       @unique
  mimeType       String
  sizeBytes      Int
  projectId      String?      @db.Uuid
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     String       @db.Uuid
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)

  @@index([organizationId, category])
  @@index([projectId])
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  action         String
  resource       String
  resourceId     String       @db.Uuid
  actorId        String       @db.Uuid
  metadata       Json?
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)

  @@index([organizationId, createdAt])
  @@index([resource, resourceId])
}

model PublicInquiry {
  id            String        @id @default(uuid()) @db.Uuid
  reference     String        @unique @db.VarChar(32)
  type          InquiryType
  status        InquiryStatus @default(NEW)
  language      String        @default("ar") @db.VarChar(2)
  sector        String
  volume        String
  fullName      String
  email         String
  phone         String?
  company       String?
  origin        String?
  destination   String?
  transportMode String?
  message       String?
  ipHash        String?
  userAgent     String?
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(6)

  @@index([status, createdAt])
  @@index([email])
}
