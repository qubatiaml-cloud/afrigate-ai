# Supabase Postgres transaction/session pooler URL used by the application.
DATABASE_URL="postgresql://prisma.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct or session-pooler URL used only by Prisma migrations.
DIRECT_URL="postgresql://prisma.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres"

# Supabase Auth and Storage. The publishable key is safe for browser use; never expose a service-role key.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"
SUPABASE_STORAGE_BUCKET="project-documents"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
